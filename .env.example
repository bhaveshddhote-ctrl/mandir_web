# Application Environment Configuration Example
# Copy this file to .env.local for local development or set these variables in Vercel / Render / Cloud Hosting settings.

# Port Configuration
PORT=3000

# Next.js Environment
NODE_ENV=development

# Database Configuration (Optional for cloud MongoDB Atlas)
# If provided, system connects to Cloud MongoDB.
# If omitted or empty, system automatically uses persistent JSON database in /data folder.
MONGODB_URI=mongodb://127.0.0.1:27017/mandir_management

# Security & Authentication Secret
NEXTAUTH_SECRET=gorakhnath_math_secret_key_108
